# ============================================================
#  .env.example — copy to .env and fill in your real values
#  NEVER commit .env to Git  (add it to .gitignore)
# ============================================================

# ── PostgreSQL (Tier 3) ──────────────────────────────────────
DB_PASSWORD=your_strong_password_here
DATABASE_URL=postgresql://postgres:your_strong_password_here@db:5432/ecommerce

# ── Flask app (Tier 2) ───────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_random_64char_hex_string

# ── Docker Hub (used by Jenkinsfile → push stage) ────────────
DOCKER_HUB_USER=yourdockerhubusername
DOCKER_HUB_TOKEN=your_dockerhub_access_token

# ── AWS EC2 (used by Jenkinsfile → deploy stage) ─────────────
EC2_HOST=ec2-xx-xx-xx-xx.compute.amazonaws.com
EC2_USER=ec2-user

# ── Jenkins (set these as Jenkins credentials, not in .env) ──
# DOCKER_HUB_CREDS  → Jenkins "Username with password" credential
# EC2_SSH_KEY       → Jenkins "SSH private key" credential

